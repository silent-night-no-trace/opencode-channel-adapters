TELEGRAM_BOT_TOKEN=
# Optional override. By default the CLI reads ~/.config/opencode/opencode-channel.json first, then .jsonc.
OPENCODE_CHANNEL_CONFIG=
OPENCODE_BASE_URL=http://127.0.0.1:4096
# Prefer OPENCODE_PASSWORD for opencode Basic auth, or OPENCODE_AUTH_HEADER for a fully custom Authorization value.
OPENCODE_PASSWORD=
OPENCODE_AUTH_HEADER=
OPENCODE_AUTH_TOKEN=
CHANNEL_SESSION_STORE=./sessions.json
TELEGRAM_ALLOWED_CHAT_IDS=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ALLOWED_CHAT_IDS=
FEISHU_WEBHOOK_HOSTNAME=127.0.0.1
FEISHU_WEBHOOK_PORT=3001
FEISHU_WEBHOOK_PATH=/feishu/events
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_ALLOWED_GUILD_IDS=
DISCORD_ALLOWED_CHANNEL_IDS=
DISCORD_IGNORE_BOTS=true
